
import gensim
import nltk
import string
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA
from nltk.tokenize import word_tokenize
from nltk.corpus import stopwords
from gensim.models import Word2Vec

nltk.download('punkt', quiet=True)
nltk.download('stopwords', quiet=True)
nltk.download('punkt_tab', quiet=True)

medical_corpus = [
    'Diabetes is a chronic disease that affects the way the body processes blood sugar.',
    'Hypertension, or high blood pressure, can lead to heart disease and stroke.',
    'The patient was diagnosed with pneumonia and prescribed antibiotics.',
    'Insulin therapy is commonly used for type 1 diabetes patients.',
    'Cardiovascular diseases are the leading cause of death worldwide.'
]

stop_words = set(stopwords.words('english'))


corpus = [
    [w for w in word_tokenize(s.lower()) if w not in stop_words and w not in string.punctuation]
    for s in medical_corpus
]
print('Processed Corpus:', corpus)


w2v = Word2Vec(sentences=corpus, vector_size=300, window=5, min_count=1, workers=4)
w2v.save('medical_word2vec.model')
w2v = Word2Vec.load('medical_word2vec.model')

print('\nVocabulary:', list(w2v.wv.index_to_key))
print('\nSimilar to diabetes:', w2v.wv.most_similar('diabetes'))

result = w2v.wv.most_similar(positive=['hypertension', 'heart'], negative=['stroke'])
print('hypertension + heart - stroke:', result)


words = list(w2v.wv.index_to_key)
vecs = [w2v.wv[w] for w in words]
reduced = PCA(n_components=2).fit_transform(vecs)

plt.figure(figsize=(8, 6))
for i, w in enumerate(words):
    plt.scatter(reduced[i, 0], reduced[i, 1])
    plt.annotate(w, (reduced[i, 0], reduced[i, 1]))
plt.title('Word Embedding Visualization (PCA)')
plt.grid(True)
plt.show()
