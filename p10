
import spacy

nlp = spacy.load('en_core_web_sm')

IPC_SECTIONS = {
    '302':  'Section 302 IPC: Punishment for murder. Whoever commits murder shall be punished with death, or imprisonment for life, and shall also be liable to fine.',
    '375':  'Section 375 IPC: Rape. This section defines what constitutes rape under Indian law.',
    '420':  'Section 420 IPC: Cheating and dishonestly inducing delivery of property.',
    '376':  'Section 376 IPC: Punishment for rape. Rigorous imprisonment of not less than 10 years, which may extend to life imprisonment, and a fine.',
    '124a': 'Section 124A IPC: Sedition – whoever, by words or signs, brings hatred or contempt against the Government shall be punished.'
}

def extract_section(user_input):
    doc = nlp(user_input)
    for i, token in enumerate(doc):
        if token.text in IPC_SECTIONS:
            return token.text
        if 'section' in token.text.lower() and i + 1 < len(doc):
            nxt = doc[i + 1].text
            if nxt in IPC_SECTIONS:
                return nxt
    return None

def detect_intent(user_input):
    if 'section' in user_input.lower() or any(s in user_input for s in IPC_SECTIONS):
        return 'ipc_query'
    if any(g in user_input.lower() for g in ['hello', 'hi']):
        return 'greeting'
    return 'general'

print("IPC Chatbot: Hello! Ask about any IPC section (e.g., 'What is Section 302?'). Type 'exit' to quit.")
while True:
    user_input = input('You: ')
    if user_input.lower() in ['exit', 'quit', 'bye']:
        print('IPC Chatbot: Goodbye!')
        break
    intent = detect_intent(user_input)
    if intent == 'ipc_query':
        sec = extract_section(user_input)
        print('IPC Chatbot:', IPC_SECTIONS[sec] if sec else "Couldn't identify section. Try 'Section 302'.")
    elif intent == 'greeting':
        print('IPC Chatbot: Hello! Ask me about any IPC section.')
    else:
        print("IPC Chatbot: I handle IPC queries. Try 'What is Section 420?'")
