from pydantic import BaseModel
from typing import List, Optional
import wikipedia, re, json

class InstitutionDetails(BaseModel):
    name: str
    founder: Optional[str] = None
    founded_year: Optional[str] = None
    branches: Optional[List[str]] = None
    number_of_employees: Optional[str] = None
    summary: str

def extract_institution_details(name: str) -> InstitutionDetails:
    try:
        page = wikipedia.page(name)
        summary = wikipedia.summary(name, sentences=6)
        content = page.content
        founder = founded_year = employees = None
        branches = []
        for line in content.split('\n'):
            ll = line.lower()
            if 'founder' in ll and not founder:
                m = re.search(r'(?i)founders?\s*[:\-]?\s*(.*)', line)
                if m:
                    val = m.group(1).strip()
                    if 0 < len(val.split()) <= 10:
                        founder = val
            if not founded_year:
                m = re.search(r'\b(?:founded|established|formed|started)\b[^0-9]{0,20}(\d{4})', ll)
                if m:
                    founded_year = m.group(1)
            if re.search(r'(branches|departments)', ll) and ':' in line:
                possible = line.split(':', 1)[-1].strip()
                if ',' in possible:
                    branches = [b.strip() for b in possible.split(',') if b.strip()]
            if ('employees' in ll or 'staff' in ll) and not employees:
                m = re.search(r'(?i)(?:employees|staff)[^\d]*(\d{1,3}(?:,\d{3})*|\d+)', line)
                if m:
                    employees = m.group(1)
        return InstitutionDetails(name=name, founder=founder, founded_year=founded_year,
                                  branches=branches or None, number_of_employees=employees,
                                  summary=summary)
    except wikipedia.exceptions.DisambiguationError as e:
        return InstitutionDetails(name=name, summary=f'Disambiguation: {e.options[:3]}')
    except wikipedia.exceptions.PageError:
        return InstitutionDetails(name=name, summary='Page not found on Wikipedia.')
    except Exception as e:
        return InstitutionDetails(name=name, summary=f'Error: {e}')

# --- Run ---
institution = input('Enter institution name: ').strip()
result = extract_institution_details(institution)
print('\n📄 Institution Details (JSON):')
print(json.dumps(result.model_dump(), indent=4))
